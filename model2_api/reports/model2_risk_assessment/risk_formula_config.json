{
  "note": "Model 2 uses domain-informed proxy targets, not clinical ground-truth future fall outcomes. Use it as mobility risk assessment for prototype testing.",
  "risk_target_formula": {
    "model2_risk_target": "max(0.6 * feature_risk_score + 0.4 * activity_prior_score, 0.95 * activity_prior_score)",
    "level_thresholds": {
      "low": "0.00 - 0.35",
      "medium": "> 0.35 - 0.7",
      "high": "> 0.7",
      "alert": "> 0.7 and high-risk probability >= 0.7"
    },
    "conservative_guard": {
      "quiet_motion_cap": 0.35,
      "minor_motion_cap": 0.55,
      "single_signal_cap": 0.55,
      "high_component_threshold": 0.65,
      "impact_component_threshold": 0.45,
      "severe_motion_threshold": 0.85,
      "min_high_components_for_high": 2
    }
  },
  "class_risk_prior": {
    "standing": 0.05,
    "lying_down": 0.05,
    "normal_walk": 0.18,
    "corrected_walking": 0.2,
    "elderly_pick_up_object": 0.38,
    "limping_walk": 0.48,
    "stand_sit_alternating": 0.52,
    "gradual_fall": 0.86,
    "slow_collapse_fall": 0.82,
    "sideways_fall": 0.92,
    "backward_fall": 0.92
  },
  "category_risk_prior": {
    "static_activity": 0.05,
    "activity": 0.32,
    "fall": 0.86
  },
  "feature_groups": {
    "gait_motion": {
      "weight": 0.22,
      "features": {
        "svm_std": 1.0,
