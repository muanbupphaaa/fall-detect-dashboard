        "omega_max": 1.0,
        "angular_impulse": 0.8,
        "high_rot_n": 0.8
      }
    },
    "posture_transition": {
      "weight": 0.2,
      "features": {
        "theta_std": 0.7,
        "theta_range": 1.0,
        "KII_mean": 0.8,
        "KII_std": 0.6,
        "KII_max": 0.8
      }
    },
    "impact_event": {
      "weight": 0.25,
      "aggregation": "max",
      "features": {
        "GSI": 1.0,
        "fcri": 1.0,
        "free_fall_n": 0.8,
        "impact_n": 0.8
      }
    },
    "physio_stress": {
